datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Ponto {
  id             Int       @id @default(autoincrement())
  username       String
  data           DateTime  @db.Date
  entrada        DateTime?
  almoco_saida   DateTime?
  almoco_retorno DateTime?
  saida_final    DateTime?

  @@unique([username, data])
}
